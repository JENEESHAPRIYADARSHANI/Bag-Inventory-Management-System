# Terraform Variables Configuration Example
# Copy this file to terraform.tfvars and update with your values

# AWS Configuration
aws_region  = "us-east-1"
environment = "development"  # development, staging, production

# Project Configuration
project_name = "quotation-service"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"

# Database Configuration
db_instance_class      = "db.t3.micro"     # Free tier eligible
db_allocated_storage   = 20                # GB
db_max_allocated_storage = 100             # GB
db_name               = "quotation_db"
db_username           = "admin"
db_password           = "YourSecurePassword123!"  # Change this!

# ECS Configuration
ecs_cpu           = 256    # 256, 512, 1024, 2048, 4096
ecs_memory        = 512    # MB - must be compatible with CPU
ecs_desired_count = 2      # Number of tasks to run
ecs_min_capacity  = 1      # Minimum for auto scaling
ecs_max_capacity  = 10     # Maximum for auto scaling

# Microservice URLs (update with actual service endpoints)
product_service_url = "http://product-service-alb.us-east-1.elb.amazonaws.com/api/products"
order_service_url   = "http://order-service-alb.us-east-1.elb.amazonaws.com/api/orders"

# Additional Tags
additional_tags = {
  Owner       = "DevOps Team"
  CostCenter  = "Engineering"
  Backup      = "Required"
}